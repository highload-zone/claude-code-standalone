# Environment Variables for MCP Servers
# Copy this file to .env and fill in your API keys.
# .env is gitignored and must NEVER be committed.

# Claude Code OAuth Token - REQUIRED for Claude Code authentication
# Get your token via: claude setup-token (or from your organization)
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token_here

# Context7 - Required for the Context7 MCP server
# Get your API key from https://context7.com
CONTEXT7_API_KEY=your_context7_api_key_here

# Perplexity - Required for the Perplexity MCP server
# Get your API key from https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
